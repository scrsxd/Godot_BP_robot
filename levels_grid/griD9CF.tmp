[node name="Player" parent="." index="27"]
position = Vector2(0, 575)
next_scene = ExtResource("6_ldtht")
intro_title = "Cesta k trysce"
intro_desc = "Radar úspěšně našel oblast, kde tryska leží. Bohužel, cesta není jednoduchá a P.3.P.4. jí sám nezvládne naplánovat. Potřebuje tvou pomoc. Sesbírej všechny vypadlé šroubky a dostaň se k trysce tak, aby mu nedošla energie uprostřed cesty. Dobíjej se bateriemi, které tryska zanechala po cestě. Nezapomeň, že nesmí vstoupit do vody!"
win_title = "Dobrá práce!"
win_text = "Skvěle! Podařilo se ti sesbírat všechny šroubky a získat zpět odpadlou trysku. Teď už ji jen zbývá připojit zpět do lodi."
win_button_text = "Pokračovat"
lose_title = "Špatná cesta"
lose_text = "Nezapomeň, že šroubky jen určují, kudy cestu vést. To těžké je vypočítat, aby ti nedošla energie před tím, než se dostaneš na konec. A samozřejmě měj na paměti, že P.3.P.4. nesmí vstoupit do vody."
