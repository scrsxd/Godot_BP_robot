[node name="Label2" type="Label" parent="CanvasLayer2/Control/NinePatchRect/MarginContainer" index="1"]
custom_minimum_size = Vector2(100, 100)
layout_mode = 2
text = "Cíl:
1. Dojít do červeného cíle, kde leží součástka.
2. Sesbírat po cestě všechny šroubky.
3. Vyhnout se vodě.

Energie:
Každý pohyb o jedno pole stojí 1 energii. Začínáš s 3.
Dobití energie: 
Pokud stoupneš na pole s baterií, její číslo se ti přičte do tvé energie.

Ovládání: 
Šipky: plánování programu cesty robota
Enter: spuštění cesty pomalu
Mezerník: spuštění cesty rychle"
label_settings = SubResource("LabelSettings_whsxl")
autowrap_mode = 2

[node name="Player" parent="." index="53"]
position = Vector2(640, 832)
next_scene = ExtResource("6_3t4dj")
intro_title = "Cesta k motoru"
intro_desc = "P.3.P.0.vi zbývá poslední cesta - k motoru. Poloha kolem motoru je větší a nabízí několik různých směrů, ale jen některé vedou k cíli. Dobře si rozmysli každý pohyb a pozorně počítej zbývající energii. Jeden zbytečný krok navíc může znamenat, že P.3.P.0.vi dojde šťáva těsně před cílem."
win_title = "Skvělá práce!"
win_text = "Skvěle! Podařilo se ti sesbírat všechny šroubky a získat zpět vypadlý motor. Teď už jen zbývá se vrátit k lodi a načíst ho do systému."
win_button_text = "Pokračovat"
lose_title = "Špatná cesta"
lose_text = "Cesta k motoru je delší a není jasné, kudy se k němu dostat, šroubky už cestu tolik neprozrazují. Zkus si vypočítat více různých cest, které P.3.P.4. ještě neprošel. A samozřejmě nezapomeň, že nesmí vstoupit do vody."

