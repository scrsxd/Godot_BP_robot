script = ExtResource("1_my2jp")
intro_title = "Najdi motor"
intro_desc = "Anténa je bezpečně připojena a radar ukazuje poslední součástku - motor. Bohužel, motor je silný stroj a dává P.3.P.0.vi zabrat nejvíc. Dokonce už nemá ani tušení, jak mají stíny vypadat a kromě dřívějších 90° se teď můžou otočit i vzhůru nohama (o 180°)."
win_title = "Super!"
win_text = "Vybral jsi správné místo. P.3.P.4. se teď může vydat na cestu."
win_button_text = "Pokračovat"
lose_title = "Špatné místo"
lose_text = "Na místě, které jsi vybral, nic není. P.3.P.4. by nic by nenašel."
allow_row_swap = true
allow_rotation_90 = true
allow_rotation_180 = true
